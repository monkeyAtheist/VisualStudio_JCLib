<Window x:Class="JCLib.VisualStudio.AppearanceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JC Lib — apparence"
        Width="640"
        Height="700"
        MinWidth="560"
        MinHeight="610"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#252526" />
        <SolidColorBrush x:Key="PanelBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DropdownTextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="TextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C8C8C8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8FC7FF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#666666" />
        <SolidColorBrush x:Key="ButtonTextBrush" Color="#111111" />
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="Button"><Setter Property="Margin" Value="0,0,6,4" /><Setter Property="Padding" Value="9,4" /><Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}" /></Style>
        <Style TargetType="TextBox"><Setter Property="Background" Value="{DynamicResource InputBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /><Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" /></Style>
        <Style x:Key="DropdownComboBoxItemStyle" TargetType="ComboBoxItem"><Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" /><Setter Property="Foreground" Value="{DynamicResource DropdownTextBrush}" /><Setter Property="Padding" Value="5,3" /></Style>
        <Style TargetType="ComboBox"><Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" /><Setter Property="Foreground" Value="{DynamicResource DropdownTextBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /><Setter Property="ItemContainerStyle" Value="{StaticResource DropdownComboBoxItemStyle}" /></Style>
    </Window.Resources>
    <Grid Margin="12">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Apparence de JC Lib" />
            <TextBlock Margin="0,4,0,10" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
                       Text="Les couleurs sont stockées localement et appliquées au navigateur ainsi qu’au Visual Pack Editor. Utilise le thème sombre accessible pour corriger les textes noirs sur fond gris." />
        </StackPanel>
        <Border Grid.Row="1" Padding="10" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="170" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Margin="0,6" Text="Fond principal" /><TextBox x:Name="BackgroundTextBox" Grid.Row="0" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="0" Grid.Column="2" Tag="BackgroundTextBox" Click="OnChooseColorClick" Content="..." />
                <TextBlock Grid.Row="1" Margin="0,6" Text="Panneaux" /><TextBox x:Name="PanelTextBox" Grid.Row="1" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="1" Grid.Column="2" Tag="PanelTextBox" Click="OnChooseColorClick" Content="..." />
                <TextBlock Grid.Row="2" Margin="0,6" Text="Champs et arbres" /><TextBox x:Name="InputTextBox" Grid.Row="2" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="2" Grid.Column="2" Tag="InputTextBox" Click="OnChooseColorClick" Content="..." />
                <TextBlock Grid.Row="3" Margin="0,6" Text="Fond listes déroulantes" /><TextBox x:Name="DropdownBackgroundTextBox" Grid.Row="3" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="3" Grid.Column="2" Tag="DropdownBackgroundTextBox" Click="OnChooseColorClick" Content="..." />
                <TextBlock Grid.Row="4" Margin="0,6" Text="Texte listes déroulantes" /><TextBox x:Name="DropdownTextTextBox" Grid.Row="4" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="4" Grid.Column="2" Tag="DropdownTextTextBox" Click="OnChooseColorClick" Content="..." />
                <TextBlock Grid.Row="5" Margin="0,6" Text="Texte principal" /><TextBox x:Name="TextTextBox" Grid.Row="5" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="5" Grid.Column="2" Tag="TextTextBox" Click="OnChooseColorClick" Content="..." />
                <TextBlock Grid.Row="6" Margin="0,6" Text="Texte secondaire" /><TextBox x:Name="SecondaryTextBox" Grid.Row="6" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="6" Grid.Column="2" Tag="SecondaryTextBox" Click="OnChooseColorClick" Content="..." />
                <TextBlock Grid.Row="7" Margin="0,6" Text="Accent" /><TextBox x:Name="AccentTextBox" Grid.Row="7" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="7" Grid.Column="2" Tag="AccentTextBox" Click="OnChooseColorClick" Content="..." />
                <TextBlock Grid.Row="8" Margin="0,6" Text="Bordures" /><TextBox x:Name="BorderTextBox" Grid.Row="8" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="8" Grid.Column="2" Tag="BorderTextBox" Click="OnChooseColorClick" Content="..." />
                <TextBlock Grid.Row="9" Margin="0,6" Text="Texte des boutons" /><TextBox x:Name="ButtonTextBox" Grid.Row="9" Grid.Column="1" Margin="0,3" Padding="5,3" TextChanged="OnThemeFieldChanged" /><Button Grid.Row="9" Grid.Column="2" Tag="ButtonTextBox" Click="OnChooseColorClick" Content="..." />
            </Grid>
        </Border>
        <Border x:Name="PreviewBorder" Grid.Row="2" Margin="0,10,0,8" Padding="10" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
            <StackPanel>
                <TextBlock FontWeight="SemiBold" Text="Aperçu" />
                <TextBlock Margin="0,4,0,0" Text="Bibliothèque > Catégorie > Groupe > Élément" />
                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="Texte secondaire et métadonnées" />
                <TextBlock Margin="0,2,0,0" Foreground="{DynamicResource AccentBrush}" Text="Accent : source du pack et liens visuels" />
                <ComboBox Margin="0,7,0,0" Width="260" HorizontalAlignment="Left" SelectedIndex="0">
                    <ComboBoxItem Content="Aperçu liste déroulante" />
                    <ComboBoxItem Content="Environnement QT" />
                    <ComboBoxItem Content="Bibliothèque CVI" />
                </ComboBox>
            </StackPanel>
        </Border>
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBlock x:Name="ValidationText" Margin="0,5,8,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" />
            <WrapPanel Grid.Column="1">
                <Button Click="OnResetDarkClick" Content="Thème sombre accessible" />
                <Button x:Name="SaveButton" Click="OnSaveClick" Content="Appliquer" />
                <Button Click="OnCancelClick" Content="Annuler" />
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
