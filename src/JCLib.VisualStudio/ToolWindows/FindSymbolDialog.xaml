<Window x:Class="JCLib.VisualStudio.FindSymbolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find Symbol"
        Width="1040" Height="720"
        MinWidth="760" MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#252526" />
        <SolidColorBrush x:Key="PanelBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="TextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C8C8C8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8FC7FF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#666666" />
        <SolidColorBrush x:Key="ButtonTextBrush" Color="#111111" />
        <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DropdownTextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="TreeRootBrush" Color="#8FC7FF" />
        <SolidColorBrush x:Key="TreePackBrush" Color="#E5C07B" />
        <SolidColorBrush x:Key="TreeEnvironmentBrush" Color="#D7BA7D" />
        <SolidColorBrush x:Key="TreeLibraryBrush" Color="#4FC1FF" />
        <SolidColorBrush x:Key="TreeCategoryBrush" Color="#569CD6" />
        <SolidColorBrush x:Key="TreeGroupBrush" Color="#C586C0" />
        <SolidColorBrush x:Key="TreeElementBrush" Color="#B5CEA8" />
        <SolidColorBrush x:Key="TreeBadgeBrush" Color="#3E3E42" />
        <SolidColorBrush x:Key="TreeIconTextBrush" Color="#111111" />
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="TextBox"><Setter Property="Background" Value="{DynamicResource InputBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /><Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="ListBox"><Setter Property="Background" Value="{DynamicResource InputBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /></Style>
        <Style TargetType="ListBoxItem"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /><Setter Property="Padding" Value="4" /></Style>
        <Style TargetType="Button"><Setter Property="Padding" Value="11,5" /><Setter Property="Margin" Value="0,0,7,0" /><Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}" /></Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="QueryTextBox"
                 Padding="8,6"
                 FontSize="16"
                 TextChanged="OnQueryTextChanged"
                 KeyDown="OnQueryKeyDown"
                 ToolTip="Nom, bibliothèque, catégorie, header, signature ou paramètre" />

        <TextBlock Grid.Row="1" Margin="0,8,0,10"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Text="La recherche démarre après la première saisie. Entrée ouvre l’élément sélectionné ; Échap ferme la fenêtre." />

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" MinWidth="300" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="4*" MinWidth="260" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="5" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                    <ListBox x:Name="ResultsListBox"
                             SelectionChanged="OnResultSelectionChanged"
                             MouseDoubleClick="OnResultDoubleClick"
                             KeyDown="OnResultsKeyDown">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="2,3">
                                    <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Path}" TextWrapping="Wrap" />
                                    <TextBlock Foreground="{DynamicResource AccentBrush}" Text="{Binding SymbolKind}" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock x:Name="ResultsStatusText" Grid.Row="1" Margin="2,7,2,2" Foreground="{DynamicResource SecondaryTextBrush}" Text="Saisis un terme pour rechercher un symbole." TextWrapping="Wrap" />
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" />

            <Border x:Name="PreviewBorder" Grid.Column="2" Padding="10" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="PreviewNameText" FontSize="17" FontWeight="SemiBold" />
                        <TextBlock x:Name="PreviewPathText" Margin="0,5,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,12,0,3" FontWeight="SemiBold" Text="Prototype / snippet" />
                        <TextBox x:Name="PreviewSignatureTextBox" MinHeight="88" Padding="6" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                        <TextBlock x:Name="PreviewDescriptionText" Margin="0,10,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <TextBlock x:Name="ShortcutHintText" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Text="Raccourci par défaut : Ctrl+Alt+P. Modifiable dans Outils > Options > Environnement > Clavier." />
            <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                <Button x:Name="OpenButton" Click="OnOpenClick" Content="Ouvrir" IsEnabled="False" />
                <Button Click="OnCancelClick" Content="Fermer" />
            </WrapPanel>
        </DockPanel>
    </Grid>
</Window>
