<Window x:Class="JCLib.VisualStudio.MoveTargetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JC Lib — choisir le nouveau parent"
        Width="760"
        Height="520"
        MinWidth="560"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#252526" />
        <SolidColorBrush x:Key="PanelBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="BorderBrush" Color="#666666" />
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DropdownTextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="TextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C8C8C8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8FC7FF" />
        <SolidColorBrush x:Key="ButtonTextBrush" Color="#111111" />
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock x:Name="HeadingText" FontSize="17" FontWeight="SemiBold" Text="Choisir le nouveau parent" />
            <TextBlock x:Name="InstructionsText" Margin="0,5,0,10" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
                       Text="Sélectionne le nouveau parent compatible." />
        </StackPanel>

        <ListBox x:Name="TargetsListBox" Grid.Row="1" DisplayMemberPath="Path" />

        <WrapPanel Grid.Row="2" Margin="0,10,0,0" HorizontalAlignment="Right">
            <Button Click="OnConfirmClick" Content="Déplacer" IsDefault="True" />
            <Button Click="OnCancelClick" Content="Annuler" IsCancel="True" />
        </WrapPanel>
    </Grid>
</Window>
