<Window x:Class="JCLib.VisualStudio.PackEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:JCLib.VisualStudio.Models"
        Title="JC Lib — Visual Pack Editor"
        Width="1380"
        Height="900"
        MinWidth="1040"
        MinHeight="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#252526" />
        <SolidColorBrush x:Key="PanelBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="BorderBrush" Color="#666666" />
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DropdownTextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="TextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C8C8C8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8FC7FF" />
        <SolidColorBrush x:Key="ButtonTextBrush" Color="#111111" />
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="Label"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,6,4" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style TargetType="TreeView">
            <Setter Property="Background" Value="{DynamicResource InputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
            <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
        </Style>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <HierarchicalDataTemplate DataType="{x:Type models:PackEditorNode}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <CheckBox Margin="0,0,5,0"
                          VerticalAlignment="Center"
                          Visibility="{Binding IsBatchSelectable, Converter={StaticResource BooleanToVisibilityConverter}}"
                          IsChecked="{Binding IsBatchSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          Click="OnBatchSelectionCheckBoxClick" />
                <TextBlock Foreground="{DynamicResource TextBrush}" Text="{Binding Header}" />
            </StackPanel>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock FontSize="19" FontWeight="SemiBold" Text="JC Lib — Visual Pack Editor avancé 1.3.7" />
            <TextBlock x:Name="PackFilePathText" Margin="0,3,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" />
        </StackPanel>

        <Border Grid.Row="1" Margin="0,10,0,8" Padding="8" Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" /><ColumnDefinition Width="1*" />
                </Grid.ColumnDefinitions>
                <TextBlock Margin="0,5,6,0" FontWeight="SemiBold" Text="Id" />
                <TextBox x:Name="PackIdTextBox" Grid.Column="1" Padding="5,3" TextChanged="OnPackMetadataChanged" />
                <TextBlock Grid.Column="2" Margin="10,5,6,0" FontWeight="SemiBold" Text="Nom" />
                <TextBox x:Name="PackNameTextBox" Grid.Column="3" Padding="5,3" TextChanged="OnPackMetadataChanged" />
                <TextBlock Grid.Column="4" Margin="10,5,6,0" FontWeight="SemiBold" Text="Version" />
                <TextBox x:Name="PackVersionTextBox" Grid.Column="5" Padding="5,3" TextChanged="OnPackMetadataChanged" />
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="5*" MinWidth="360" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="7*" MinWidth="520" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Padding="6" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Margin="0,0,0,6" FontWeight="SemiBold" Text="Hiérarchie du pack" />
                    <TreeView x:Name="EditorTreeView" Grid.Row="1" SelectedItemChanged="OnEditorTreeSelectionChanged" />
                    <StackPanel Grid.Row="2" Margin="0,7,0,0">
                        <WrapPanel>
                            <Button x:Name="AddEnvironmentButton" Click="OnAddEnvironmentClick" Content="+ Environnement" Visibility="Collapsed" />
                            <Button x:Name="AddLibraryButton" Click="OnAddLibraryClick" Content="+ Bibliothèque" IsEnabled="False" />
                            <Button x:Name="AddCategoryButton" Click="OnAddCategoryClick" Content="+ Catégorie" IsEnabled="False" />
                            <Button x:Name="AddGroupButton" Click="OnAddGroupClick" Content="+ Groupe" IsEnabled="False" />
                        </WrapPanel>
                        <WrapPanel>
                            <Button x:Name="AddElementButton" Click="OnAddElementClick" Content="+ Élément" IsEnabled="False" />
                            <Button x:Name="DeleteStructureButton" Click="OnDeleteStructureClick" Content="Supprimer le nœud" IsEnabled="False" />
                            <Button x:Name="DeleteElementButton" Click="OnDeleteElementClick" Content="Supprimer l'élément" IsEnabled="False" />
                        </WrapPanel>
                        <WrapPanel>
                            <Button x:Name="DuplicateSubtreeButton" Click="OnDuplicateSubtreeClick" Content="Dupliquer le sous-arbre" IsEnabled="False" />
                            <Button x:Name="ExportPartialButton" Click="OnExportPartialClick" Content="Exporter le sous-arbre" IsEnabled="False" />
                            <Button x:Name="ImportPartialButton" Click="OnImportPartialClick" Content="Importer un fragment" IsEnabled="False" />
                        </WrapPanel>
                        <Border Margin="0,7,0,0" Padding="6" Background="{DynamicResource BackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                            <StackPanel>
                                <TextBlock x:Name="BatchSelectionSummaryText" FontWeight="SemiBold" Text="Sélection groupée : 0 élément" />
                                <TextBlock Margin="0,2,0,5" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"
                                           Text="Coche plusieurs éléments pour une opération groupée. Sans case cochée, les actions s’appliquent au nœud sélectionné, y compris aux sous-arbres compatibles." />
                                <WrapPanel>
                                    <Button x:Name="DuplicateSelectionButton" Click="OnDuplicateSelectionClick" Content="Dupliquer" IsEnabled="False" />
                                    <Button x:Name="MoveUpButton" Click="OnMoveUpClick" Content="Monter" IsEnabled="False" />
                                    <Button x:Name="MoveDownButton" Click="OnMoveDownClick" Content="Descendre" IsEnabled="False" />
                                    <Button x:Name="ChangeParentButton" Click="OnChangeParentClick" Content="Changer de parent" IsEnabled="False" />
                                </WrapPanel>
                                <WrapPanel>
                                    <Button x:Name="DeleteSelectionButton" Click="OnDeleteSelectionClick" Content="Supprimer la sélection" IsEnabled="False" />
                                    <Button x:Name="ClearBatchSelectionButton" Click="OnClearBatchSelectionClick" Content="Effacer la sélection" IsEnabled="False" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource BorderBrush}" />

            <Border Grid.Column="2" Padding="8" Background="{DynamicResource PanelBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" FontSize="15" Text="Édition du nœud sélectionné" />
                        <TextBlock x:Name="SelectedElementPathText" Margin="0,3,0,8" Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="Sélectionne un nœud dans l'arborescence." TextWrapping="Wrap" />

                        <StackPanel x:Name="NodeFieldsPanel" Visibility="Collapsed">
                            <TextBlock Margin="0,0,0,3" FontWeight="SemiBold" Text="Nom du nœud" />
                            <TextBox x:Name="NodeNameTextBox" TextChanged="OnNodeNameChanged" />
                            <TextBlock Margin="0,5,0,10" Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="Le renommage s'applique aux bibliothèques, catégories et groupes." TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel x:Name="ElementFieldsPanel" Visibility="Collapsed">
                            <TextBlock Margin="0,0,0,3" FontWeight="SemiBold" Text="Nom" />
                            <TextBox x:Name="ElementNameTextBox" Tag="name" TextChanged="OnElementFieldChanged" />

                            <TextBlock Margin="0,8,0,3" FontWeight="SemiBold" Text="Type de symbole" />
                            <TextBox x:Name="SymbolKindTextBox" Tag="symbolKind" TextChanged="OnElementFieldChanged" />

                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="8" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,3" FontWeight="SemiBold" Text="Type de retour" />
                                    <TextBox x:Name="ReturnTypeTextBox" Tag="returnType" TextChanged="OnElementFieldChanged" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Margin="0,0,0,3" FontWeight="SemiBold" Text="Header" />
                                    <TextBox x:Name="HeaderTextBox" Tag="header" TextChanged="OnElementFieldChanged" />
                                </StackPanel>
                            </Grid>

                            <TextBlock Margin="0,8,0,3" FontWeight="SemiBold" Text="Signature" />
                            <TextBox x:Name="SignatureTextBox" Tag="signature" TextChanged="OnElementFieldChanged" />
                            <TextBlock Margin="0,8,0,3" FontWeight="SemiBold" Text="Déclaration" />
                            <TextBox x:Name="DeclarationTextBox" Tag="declaration" TextChanged="OnElementFieldChanged" />
                            <TextBlock Margin="0,8,0,3" FontWeight="SemiBold" Text="Snippet inséré" />
                            <TextBox x:Name="InsertTextTextBox" MinHeight="120" AcceptsReturn="True" AcceptsTab="True"
                                     FontFamily="Consolas" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                     Tag="insertText" TextChanged="OnElementFieldChanged" />
                            <TextBlock Margin="0,8,0,3" FontWeight="SemiBold" Text="Description" />
                            <TextBox x:Name="DescriptionTextBox" Tag="description" TextChanged="OnElementFieldChanged" />
                            <TextBlock Margin="0,8,0,3" FontWeight="SemiBold" Text="Description longue" />
                            <TextBox x:Name="LongDescriptionTextBox" MinHeight="70" AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto" Tag="longDescription" TextChanged="OnElementFieldChanged" />

                            <Expander x:Name="ParametersExpander" Margin="0,12,0,0" Header="Paramètres structurés" IsExpanded="True">
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5*" MinWidth="190" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="7*" MinWidth="250" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <ListBox x:Name="ParametersListBox" MinHeight="150" MaxHeight="240"
                                                 DisplayMemberPath="Display" SelectionChanged="OnParameterSelectionChanged" />
                                        <WrapPanel Margin="0,6,0,0">
                                            <Button x:Name="AddParameterButton" Click="OnAddParameterClick" Content="+ Paramètre" />
                                            <Button x:Name="DeleteParameterButton" Click="OnDeleteParameterClick" Content="Supprimer" IsEnabled="False" />
                                        </WrapPanel>
                                    </StackPanel>
                                    <GridSplitter Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{DynamicResource BorderBrush}" />
                                    <StackPanel x:Name="ParameterFieldsPanel" Grid.Column="2" Visibility="Collapsed">
                                        <TextBlock FontWeight="SemiBold" Text="Nom du paramètre" />
                                        <TextBox x:Name="ParameterNameTextBox" Margin="0,3,0,0" Tag="name" TextChanged="OnParameterFieldChanged" />
                                        <TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Type" />
                                        <TextBox x:Name="ParameterTypeTextBox" Margin="0,3,0,0" Tag="type" TextChanged="OnParameterFieldChanged" />
                                        <TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Description du paramètre" />
                                        <TextBox x:Name="ParameterDescriptionTextBox" Margin="0,3,0,0" Tag="description" TextChanged="OnParameterFieldChanged" />
                                        <TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Type d'éditeur" />
                                        <TextBox x:Name="ParameterEditorTypeTextBox" Margin="0,3,0,0" Tag="editorType" TextChanged="OnParameterFieldChanged" />
                                        <TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Valeur par défaut" />
                                        <TextBox x:Name="ParameterDefaultValueTextBox" Margin="0,3,0,0" Tag="defaultValue" TextChanged="OnParameterFieldChanged" />
                                        <TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Placeholder" />
                                        <TextBox x:Name="ParameterPlaceholderTextBox" Margin="0,3,0,0" Tag="placeholder" TextChanged="OnParameterFieldChanged" />
                                        <CheckBox x:Name="ParameterOptionalCheckBox" Margin="0,7,0,0" Content="Paramètre facultatif" Checked="OnParameterOptionalChanged" Unchecked="OnParameterOptionalChanged" />
                                        <TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Presets (valeur ou valeur | label | description | détail)" />
                                        <TextBox x:Name="ParameterPresetsTextBox" Margin="0,3,0,0" MinHeight="54" AcceptsReturn="True"
                                                 Tag="presets" TextChanged="OnParameterListFieldChanged" />
                                        <TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="Options (valeur ou valeur | label | description | détail)" />
                                        <TextBox x:Name="ParameterOptionsTextBox" Margin="0,3,0,0" MinHeight="54" AcceptsReturn="True"
                                                 Tag="options" TextChanged="OnParameterListFieldChanged" />
                                        <TextBlock Margin="0,7,0,0" FontWeight="SemiBold" Text="pickerConfig JSON (fenêtre structurée, sélection multiple, séparateur)" />
                                        <TextBox x:Name="ParameterPickerConfigTextBox" Margin="0,3,0,0" MinHeight="110" AcceptsReturn="True" AcceptsTab="True"
                                                 FontFamily="Consolas" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                                                 LostFocus="OnParameterPickerConfigLostFocus" />
                                    </StackPanel>
                                </Grid>
                            </Expander>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <Expander x:Name="ValidationExpander" Grid.Row="3" Margin="0,8,0,0" Header="Validation" IsExpanded="False">
            <ListBox x:Name="ValidationIssuesListBox" Margin="0,6,0,0" MinHeight="65" MaxHeight="150" DisplayMemberPath="Display" />
        </Expander>

        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
            <TextBlock x:Name="EditorStatusText" Margin="0,6,8,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="Chargement du pack..." TextWrapping="Wrap" />
            <WrapPanel Grid.Column="1">
                <Button Click="OnValidateClick" Content="Valider" />
                <Button x:Name="SaveButton" Click="OnSaveClick" Content="Sauvegarder" IsEnabled="False" />
                <Button x:Name="SaveAndCloseButton" Click="OnSaveAndCloseClick" Content="Sauvegarder et fermer" IsEnabled="False" />
                <Button Click="OnCloseClick" Content="Fermer" />
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
