<UserControl x:Class="JCLib.VisualStudio.JCLibToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:JCLib.VisualStudio.Models"
             MinWidth="760" MinHeight="480"
             Background="{DynamicResource BackgroundBrush}"
             Foreground="{DynamicResource TextBrush}">
    <UserControl.Resources>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#252526" />
        <SolidColorBrush x:Key="PanelBrush" Color="#2D2D30" />
        <SolidColorBrush x:Key="InputBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="#1E1E1E" />
        <SolidColorBrush x:Key="DropdownTextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="TextBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#C8C8C8" />
        <SolidColorBrush x:Key="AccentBrush" Color="#8FC7FF" />
        <SolidColorBrush x:Key="BorderBrush" Color="#666666" />
        <SolidColorBrush x:Key="ButtonTextBrush" Color="#111111" />
        <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="Label"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="Button"><Setter Property="Margin" Value="0,0,6,0" /><Setter Property="Padding" Value="10,5" /><Setter Property="Foreground" Value="{DynamicResource ButtonTextBrush}" /></Style>
        <Style TargetType="TextBox"><Setter Property="Background" Value="{DynamicResource InputBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /><Setter Property="CaretBrush" Value="{DynamicResource TextBrush}" /></Style>
        <Style x:Key="DropdownComboBoxItemStyle" TargetType="ComboBoxItem"><Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" /><Setter Property="Foreground" Value="{DynamicResource DropdownTextBrush}" /><Setter Property="Padding" Value="5,3" /></Style>
        <Style TargetType="ComboBox"><Setter Property="Background" Value="{DynamicResource DropdownBackgroundBrush}" /><Setter Property="Foreground" Value="{DynamicResource DropdownTextBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /><Setter Property="ItemContainerStyle" Value="{StaticResource DropdownComboBoxItemStyle}" /></Style>
        <Style TargetType="CheckBox"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="Expander"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <Style TargetType="TreeView"><Setter Property="Background" Value="{DynamicResource InputBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /></Style>
        <Style TargetType="TreeViewItem"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /><Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" /><Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" /></Style>
        <Style TargetType="ListBox"><Setter Property="Background" Value="{DynamicResource InputBrush}" /><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /><Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" /></Style>
        <Style TargetType="ListBoxItem"><Setter Property="Foreground" Value="{DynamicResource TextBrush}" /></Style>
        <HierarchicalDataTemplate DataType="{x:Type models:CatalogNode}" ItemsSource="{Binding Children}">
            <TextBlock Foreground="{DynamicResource TextBrush}" Text="{Binding Header}" />
        </HierarchicalDataTemplate>
        <DataTemplate x:Key="QuickEntryTemplate">
            <StackPanel Margin="2,2">
                <TextBlock FontWeight="SemiBold" Text="{Binding Name}" />
                <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Path}" TextWrapping="Wrap" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="JC Lib — navigateur multi-pack" />
                <TextBlock x:Name="CatalogSummaryText" Margin="0,3,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="Chargement des catalogues..." />
            </StackPanel>
            <WrapPanel Grid.Column="1" Margin="8,0,0,0">
                <Button Click="OnAppearanceClick" Content="Apparence" ToolTip="Configurer les couleurs de JC Lib" />
                <Button Click="OnReloadCatalogClick" Content="Recharger" />
            </WrapPanel>
        </Grid>
        <WrapPanel Grid.Row="1" Margin="0,10,0,4">
            <Button Click="OnCreatePackClick" Content="Créer un pack" />
            <Button Click="OnImportGlobalPackClick" Content="Importer un pack global" />
            <Button Click="OnImportSolutionPackClick" Content="Importer pour la solution" />
            <Button Click="OnOpenGlobalPacksFolderClick" Content="Ouvrir les packs globaux" />
            <Button Click="OnOpenSolutionPacksFolderClick" Content="Ouvrir les packs solution" />
            <CheckBox x:Name="AutoReloadCheckBox" Margin="4,6,10,0" IsChecked="True" Checked="OnAutoReloadChanged" Unchecked="OnAutoReloadChanged" Content="Rechargement automatique" />
            <CheckBox x:Name="IncludeBundledPackCheckBox" Margin="0,6,0,0" Checked="OnIncludeBundledPackChanged" Unchecked="OnIncludeBundledPackChanged" Content="Inclure le pack embarqué (fallback)" ToolTip="Désactive cette option pour utiliser uniquement les packs générés ou importés depuis l’extension VS Code." />
        </WrapPanel>
        <Expander x:Name="PackManagementExpander" Grid.Row="2" Margin="0,4,0,4" Header="Gestion des packs — priorité solution &gt; global &gt; embarqué" IsExpanded="False">
            <Grid Margin="0,6,0,0"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <ListBox x:Name="PackManagementListBox" MinHeight="76" MaxHeight="150" SelectionChanged="OnPackManagementSelectionChanged" DisplayMemberPath="ManagementDisplay" />
                <WrapPanel Grid.Row="1" Margin="0,6,0,0">
                    <Button x:Name="ToggleSelectedPackButton" Click="OnToggleSelectedPackClick" Content="Activer / désactiver" IsEnabled="False" />
                    <Button x:Name="EditSelectedPackButton" Click="OnEditSelectedPackClick" Content="Éditer le pack externe" IsEnabled="False" />
                    <Button x:Name="DuplicateSelectedPackButton" Click="OnDuplicateSelectedPackClick" Content="Dupliquer le pack" IsEnabled="False" />
                    <Button x:Name="DeleteSelectedPackButton" Click="OnDeleteSelectedPackClick" Content="Supprimer le pack externe" IsEnabled="False" />
                    <Button x:Name="OpenSelectedPackFolderButton" Click="OnOpenSelectedPackFolderClick" Content="Ouvrir le dossier du pack" IsEnabled="False" />
                    <TextBlock x:Name="PackManagementHintText" Margin="4,6,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" Text="Sélectionne un pack externe pour le gérer. Le pack embarqué est un fallback optionnel en lecture seule." />
                </WrapPanel>
            </Grid>
        </Expander>
        <Expander x:Name="DiagnosticsExpander" Grid.Row="3" Margin="0,4,0,4" Header="Sources et diagnostics" IsExpanded="False">
            <TextBox x:Name="DiagnosticsTextBox" Margin="0,6,0,0" MinHeight="80" MaxHeight="190" Padding="6" AcceptsReturn="True" FontFamily="Consolas" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
        </Expander>
        <Expander x:Name="QuickAccessExpander" Grid.Row="4" Margin="0,4,0,4" Header="Accès rapides — favoris et éléments récents" IsExpanded="False">
            <Grid Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Favoris"/><ListBox x:Name="FavoritesListBox" MinHeight="72" MaxHeight="145" ItemTemplate="{StaticResource QuickEntryTemplate}" SelectionChanged="OnQuickAccessSelectionChanged" MouseDoubleClick="OnQuickAccessDoubleClick"/></StackPanel>
                <GridSplitter Grid.Column="1" Background="{DynamicResource BorderBrush}" />
                <StackPanel Grid.Column="2"><TextBlock Margin="0,0,0,4" FontWeight="SemiBold" Text="Récents"/><ListBox x:Name="RecentListBox" MinHeight="72" MaxHeight="145" ItemTemplate="{StaticResource QuickEntryTemplate}" SelectionChanged="OnQuickAccessSelectionChanged" MouseDoubleClick="OnQuickAccessDoubleClick"/></StackPanel>
            </Grid>
        </Expander>
        <WrapPanel Grid.Row="5" Margin="0,5,0,5">
            <TextBlock Margin="0,5,6,0" FontWeight="SemiBold" Text="Environnement"/><ComboBox x:Name="EnvironmentFilterComboBox" Width="170" Margin="0,0,10,0" SelectionChanged="OnEnvironmentFilterChanged" />
            <TextBlock Margin="0,5,6,0" FontWeight="SemiBold" Text="Bibliothèque"/><ComboBox x:Name="LibraryFilterComboBox" Width="190" Margin="0,0,10,0" SelectionChanged="OnLibraryFilterChanged" />
            <CheckBox x:Name="FavoritesOnlyCheckBox" Margin="0,5,10,0" Click="OnFavoritesOnlyChanged" Content="Favoris uniquement" />
            <Button Click="OnResetFiltersClick" Content="Réinitialiser les filtres" />
        </WrapPanel>
        <Grid Grid.Row="6" Margin="0,2,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock Margin="0,4,8,0" FontWeight="SemiBold" Text="Recherche" />
            <TextBox x:Name="SearchTextBox" Grid.Column="1" Padding="6,4" TextChanged="OnSearchTextChanged" ToolTip="Nom, prototype, chemin, source, description, paramètre ou snippet" />
            <Button Grid.Column="2" Margin="8,0,0,0" Click="OnClearSearchClick" Content="Effacer" />
        </Grid>
        <Grid Grid.Row="7"><Grid.ColumnDefinitions><ColumnDefinition Width="5*" MinWidth="260"/><ColumnDefinition Width="8"/><ColumnDefinition Width="7*" MinWidth="380"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Padding="6" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                <Grid>
                    <TreeView x:Name="CatalogTreeView" SelectedItemChanged="OnCatalogTreeSelectionChanged" />
                    <ListBox x:Name="SearchResultsListBox" Visibility="Collapsed" SelectionChanged="OnSearchResultSelectionChanged" MouseDoubleClick="OnSearchResultDoubleClick">
                        <ListBox.ItemTemplate><DataTemplate><StackPanel Margin="2,3"><TextBlock FontWeight="SemiBold" Text="{Binding Name}"/><TextBlock Foreground="{DynamicResource SecondaryTextBrush}" Text="{Binding Path}" TextWrapping="Wrap"/><TextBlock Foreground="{DynamicResource AccentBrush}" Text="{Binding SourceDisplay}" TextWrapping="Wrap"/></StackPanel></DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="1" Background="{DynamicResource BorderBrush}" ResizeDirection="Columns" />
            <Border Grid.Column="2" Padding="10" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                <ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel>
                    <TextBlock x:Name="SelectedNameText" FontSize="16" FontWeight="SemiBold" Text="Sélectionne un élément" />
                    <TextBlock x:Name="SelectedPathText" Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" />
                    <TextBlock x:Name="SelectedMetaText" Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap" />
                    <TextBlock Margin="0,12,0,3" FontWeight="SemiBold" Text="Prototype" />
                    <TextBox x:Name="SignatureTextBox" MinHeight="48" Padding="6" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" />
                    <Expander x:Name="ParametersExpander" Margin="0,12,0,0" Header="Paramètres de l'appel" IsExpanded="True" Visibility="Collapsed">
                        <StackPanel Margin="0,8,0,0"><TextBlock x:Name="ParametersSummaryText" Margin="0,0,0,6" Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/><StackPanel x:Name="ParametersPanel"/><Grid x:Name="ReturnTargetGrid" Margin="0,8,0,0" Visibility="Collapsed"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Margin="0,5,8,0" Text="Variable de retour"/><TextBox x:Name="ReturnTargetTextBox" Grid.Column="1" Padding="5,3" TextChanged="OnReturnTargetTextChanged"/></Grid><Button Margin="0,8,0,0" HorizontalAlignment="Left" Click="OnResetParametersClick" Content="Réinitialiser les paramètres"/></StackPanel>
                    </Expander>
                    <TextBlock Margin="0,12,0,3" FontWeight="SemiBold" Text="Snippet généré" />
                    <TextBox x:Name="SnippetTextBox" MinHeight="150" MaxHeight="320" Padding="6" AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" IsReadOnly="True" TextWrapping="NoWrap" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" />
                    <TextBlock x:Name="DescriptionText" Margin="0,10,0,8" TextWrapping="Wrap" />
                    <WrapPanel>
                        <Button x:Name="InsertSnippetButton" Click="OnInsertSnippetClick" Content="Insérer dans l’éditeur" IsEnabled="False" />
                        <Button x:Name="QuickInsertSnippetButton" Click="OnQuickInsertSelectedClick" Content="Insertion rapide (défauts)" IsEnabled="False" ToolTip="Insérer immédiatement les valeurs par défaut" />
                        <Button x:Name="CopySnippetButton" Click="OnCopySnippetClick" Content="Copier le snippet" IsEnabled="False" />
                        <Button x:Name="ExecuteSnippetButton" Click="OnExecuteSnippetClick" Content="Exécuter dans une console" IsEnabled="False" ToolTip="Exécuter les cartes de commande et les recettes Scripting / System dans une console externe adaptée" />
                        <Button x:Name="FavoriteToggleButton" Click="OnToggleFavoriteClick" Content="☆ Ajouter aux favoris" IsEnabled="False" />
                    </WrapPanel>
                </StackPanel></ScrollViewer>
            </Border>
        </Grid>
        <TextBlock x:Name="StatusText" Grid.Row="8" Margin="0,8,0,0" Foreground="{DynamicResource SecondaryTextBrush}" Text="Initialisation..." TextWrapping="Wrap" />
    </Grid>
</UserControl>
